{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/engines/recurring-tasks",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/engines/watchdog",
      "schedule": "0 4 * * *"
    }
  ]
}
