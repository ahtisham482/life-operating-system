NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push Notifications
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Groq LLM (used for AI habit coaching interview)
GROQ_API_KEY=your-groq-api-key

# Cron engine auth — set a strong random string in production
CRON_SECRET=your-cron-secret
# Supabase pg_cron secret — stored in Supabase Vault, used by pg_cron for per-minute notification checks
SUPABASE_CRON_SECRET=your-supabase-cron-secret
